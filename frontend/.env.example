# TelemetryPulse Frontend Environment Variables

# The WebSocket URL for the backend telemetry stream.
# Local development: ws://localhost:8080/ws
# Production: wss://your-backend-domain.com/ws
VITE_WS_URL=ws://localhost:8080/ws

# The HTTP API URL for backend commands (e.g., failure injection).
# Local development: http://localhost:8080/api/simulate
# Production: https://your-backend-domain.com/api/simulate
VITE_API_URL=http://localhost:8080/api/simulate
